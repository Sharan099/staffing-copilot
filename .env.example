# Copy to .env and fill in values. Never commit .env to git.
JWT_SECRET=replace-with-a-long-random-string
# Generate with: openssl rand -hex 32
MASTER_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32
# Optional: directory for SQLite files (Docker sets this to /data)
# STAFFING_DATA_DIR=.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8080,http://localhost:8080,null
ANTHROPIC_API_TIMEOUT_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
# Admin confirmation only — NOT auto-detected. Set true after your team verifies each provider.
# Anthropic ZDR: request via sales/account team (per org); NOT a self-serve console toggle.
# Groq ZDR: GroqCloud Console → Data Controls (org admin).
ANTHROPIC_ZDR_CONFIRMED=false
GROQ_ZDR_CONFIRMED=false
